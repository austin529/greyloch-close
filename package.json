{
  "name": "greyloch-close",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:web": "vite",
    "build": "vite build",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "cf-typegen": "wrangler types",
    "db:create": "wrangler d1 create greyloch-close",
    "db:migrate:local": "wrangler d1 migrations apply greyloch-close --local",
    "db:migrate:remote": "wrangler d1 migrations apply greyloch-close --remote",
    "db:reset:local": "rm -rf .wrangler/state && npm run db:migrate:local"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "jose": "^5.9.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "wrangler": "^4.20.0"
  }
}
